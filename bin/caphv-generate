  # ─── MachineHealthCheck ───
  cat <<EOF
apiVersion: cluster.x-k8s.io/v1beta1
kind: MachineHealthCheck
metadata:
  name: ${NAME}-mhc
  namespace: ${NAMESPACE}
spec:
  clusterName: ${NAME}
  maxUnhealthy: 34%
  nodeStartupTimeout: 20m
  selector:
    matchLabels:
      cluster.x-k8s.io/cluster-name: ${NAME}
  unhealthyConditions:
    - type: Ready
      status: "False"
      timeout: 5m
    - type: Ready
      status: Unknown
      timeout: 5m
EOF
}

# ─── Parse Arguments ─────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)              NAME="$2";              shift 2 ;;
    --namespace)         NAMESPACE="$2";         shift 2 ;;
    --cp-replicas)       CP_REPLICAS="$2";       shift 2 ;;
    --worker-replicas)   WORKER_REPLICAS="$2";   shift 2 ;;
    --k8s-version)       K8S_VERSION="$2";       shift 2 ;;
    --cpu)               CPU="$2";               shift 2 ;;
    --memory)            MEMORY="$2";            shift 2 ;;
    --image)             IMAGE="$2";             shift 2 ;;
    --disk-size)         DISK_SIZE="$2";         shift 2 ;;
    --extra-disk)        EXTRA_DISK="$2";        shift 2 ;;
    --ssh-keypair)       SSH_KEYPAIR="$2";       shift 2 ;;
    --ssh-user)          SSH_USER="$2";          shift 2 ;;
    --network)           NETWORK="$2";           shift 2 ;;
    --gateway)           GATEWAY="$2";           shift 2 ;;
    --subnet-mask)       SUBNET_MASK="$2";       shift 2 ;;
    --ip-pool)           IP_POOL="$2";           shift 2 ;;
    --ip-pool-refs)      IP_POOL_REFS="$2";      shift 2 ;;
    --dns)               DNS="$2";               shift 2 ;;
    --cni)               CNI="$2";               shift 2 ;;
    --harvester-kubeconfig) HARVESTER_KUBECONFIG="$2"; shift 2 ;;
    --class)             CLASS="$2";             shift 2 ;;
    --apply)             APPLY=true; DRY_RUN=false; shift ;;
    --dry-run)           DRY_RUN=true;           shift ;;
    --interactive)       INTERACTIVE=true;       shift ;;
    --help|-h)           usage ;;
    *)                   die "Unknown flag: $1" ;;
  esac
done

# ─── Main ────────────────────────────────────────────────────────────
if [[ "$INTERACTIVE" == true ]]; then
  interactive_mode
fi

validate

if [[ "$APPLY" == true ]]; then
  echo "Generating and applying manifests for cluster '${NAME}'..." >&2
  generate | kubectl apply -f -
  echo "" >&2
  echo "Cluster '${NAME}' manifests applied to namespace '${NAMESPACE}'." >&2
  echo "Monitor with: kubectl get cluster,harvestermachine,machine -n ${NAMESPACE}" >&2
else
  generate
fi
